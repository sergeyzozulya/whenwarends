---
// Pure-SVG trend badge: a compact sparkline + a signed percentage-point delta.
// No hydration, no <script>; geometry is computed deterministically here.
// Drives the hero consensus trend and each stat card's trend. Editorial:
// accent stroke, muted neutral delta (no green/red value judgement), sentence
// case. Inline CSS is allowed only inside <svg> (per CLAUDE.md).

interface Props {
  /** Chronological 0–1 values for the sparkline. */
  points: number[];
  /** Signed change in percentage points vs the comparison point, or null. */
  deltaPts: number | null;
  /** Days spanned by the delta, for an honest "{n}d" label. */
  deltaDays: number | null;
  /** Total stored points all-time. Below 2, the badge renders nothing (§8.7). */
  count: number;
  /** Localized strings: { pts, daysAgo ("{n}d" template) }. */
  strings: { pts: string; daysAgo: string };
  width?: number;
  height?: number;
}

const {
  points,
  deltaPts,
  deltaDays,
  count,
  strings,
  width = 92,
  height = 26,
} = Astro.props;

const pad = 3;
const innerW = Math.max(1, width - pad * 2);
const innerH = Math.max(1, height - pad * 2);
const series = (points ?? []).filter((n) => Number.isFinite(n));
const baselineY = pad + innerH / 2;

let polylinePoints = '';
let lastX = pad + innerW;
let lastY = baselineY;

if (series.length === 1) {
  const norm = Math.min(1, Math.max(0, series[0]!));
  const y = pad + innerH - norm * innerH;
  polylinePoints = `${pad},${y} ${pad + innerW},${y}`;
  lastY = y;
} else if (series.length > 1) {
  const min = Math.min(...series);
  const max = Math.max(...series);
  const range = max - min;
  const n = series.length;
  const coords = series.map((v, i) => {
    const x = pad + (i / (n - 1)) * innerW;
    const t = range === 0 ? 0.5 : (v - min) / range;
    const y = pad + innerH - t * innerH;
    return { x, y };
  });
  polylinePoints = coords.map((c) => `${c.x},${c.y}`).join(' ');
  const last = coords[n - 1]!;
  lastX = last.x;
  lastY = last.y;
}

const accent = 'var(--color-accent)';

// §8.7: a trend renders only with ≥2 stored points. Below that — nothing.
const show = count >= 2 && series.length >= 2;

let deltaText = '';
if (show && deltaPts !== null) {
  const rounded = Math.round(deltaPts);
  const sign = rounded > 0 ? '+' : rounded < 0 ? '−' : '±';
  const daysLabel = strings.daysAgo.replace('{n}', String(deltaDays ?? 0));
  deltaText = `${sign}${Math.abs(rounded)} ${strings.pts} · ${daysLabel}`;
}
---

{
  show && (
    <div class="inline-flex items-center gap-2.5 text-[13px] text-[var(--color-muted)]">
      <svg
        aria-hidden="true"
        width={width}
        height={height}
        viewBox={`0 0 ${width} ${height}`}
        preserveAspectRatio="none"
        style="display:block;overflow:visible"
      >
        <polyline
          points={polylinePoints}
          fill="none"
          stroke={accent}
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
        <circle cx={lastX} cy={lastY} r="2" fill={accent} stroke="none" />
      </svg>
      {deltaText && <span class="tabular-nums">{deltaText}</span>}
    </div>
  )
}
