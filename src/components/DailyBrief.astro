---
import type { BriefRow, Citation, Lang } from '@lib/types';
import { getTranslation } from '@i18n/index';

interface Props {
  /** The latest PUBLISHED brief for this lang, or null. */
  brief: BriefRow | null;
  /** True when showing last week's brief because no fresh one was approved. */
  isStale?: boolean;
  lang: Lang;
}

const { brief, isStale = false, lang } = Astro.props;

const headingLabel = getTranslation(lang, 'brief.heading');
const noBriefLabel = getTranslation(lang, 'brief.noBrief');
const sourcesLabel = getTranslation(lang, 'brief.sources');
const reviewedLabel = getTranslation(lang, 'brief.reviewed');

// Drafts are never public. Only render published text; if it is null, the
// brief is treated as absent (no fresh brief notice).
const publishedText =
  brief != null && brief.published != null ? brief.published : null;
const hasBrief = publishedText != null;

// Per SPEC §10: when stale, the previous week's brief stays visible but with
// the "no fresh brief this week" notice above it.
const showNoBriefNotice = !hasBrief || (isStale && hasBrief);

// Parse citations defensively. Malformed or non-conforming JSON yields [].
function parseCitations(raw: string | undefined): Citation[] {
  if (!raw) return [];
  try {
    const parsed: unknown = JSON.parse(raw);
    if (!Array.isArray(parsed)) return [];
    return parsed.filter(
      // Narrow each entry to the Citation contract; drop anything malformed.
      (c): c is Citation =>
        typeof c === 'object' &&
        c !== null &&
        typeof (c as { source?: unknown }).source === 'string' &&
        typeof (c as { url?: unknown }).url === 'string',
    );
  } catch {
    return [];
  }
}

const citations: Citation[] = hasBrief ? parseCitations(brief?.citations) : [];

// Localized published date, fixed to UTC per project time conventions.
const localeByLang: Record<Lang, string> = {
  uk: 'uk-UA',
  en: 'en-US',
  ru: 'ru-RU',
};

function formatDate(date: string | undefined): string | null {
  if (!date) return null;
  const d = new Date(`${date}T00:00:00Z`);
  if (Number.isNaN(d.getTime())) return null;
  return new Intl.DateTimeFormat(localeByLang[lang], {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  }).format(d);
}

const publishedDate = hasBrief ? formatDate(brief?.date) : null;
---

<section
  class="mx-auto max-w-prose px-4 py-8"
  aria-labelledby="daily-brief-heading"
>
  <h2
    id="daily-brief-heading"
    class="text-[22px] font-medium leading-tight text-gray-900"
  >
    {headingLabel}
  </h2>

  {
    showNoBriefNotice && (
      <p class="mt-3 text-sm font-normal text-gray-500" role="status">
        {noBriefLabel}
      </p>
    )
  }

  {
    hasBrief && (
      <>
        <div class="mt-3 flex flex-wrap items-baseline gap-x-3 gap-y-1">
          {publishedDate && (
            <time
              datetime={brief?.date}
              class="text-xs font-normal text-gray-500"
            >
              {publishedDate}
            </time>
          )}
          <span class="text-xs font-medium text-gray-600">
            {reviewedLabel}
          </span>
        </div>

        <div class="mt-4 space-y-4">
          {publishedText
            ?.split(/\n{2,}/)
            .map((para) => para.trim())
            .filter((para) => para.length > 0)
            .map((para) => (
              <p class="text-base font-normal leading-relaxed text-gray-800">
                {para}
              </p>
            ))}
        </div>

        {citations.length > 0 && (
          <div class="mt-6">
            <h3 class="text-sm font-medium text-gray-700">{sourcesLabel}</h3>
            <ul class="mt-2 space-y-1">
              {citations.map((citation) => (
                <li class="text-sm font-normal text-gray-700">
                  <a
                    href={citation.url}
                    rel="noopener noreferrer"
                    target="_blank"
                    class="text-[#2c5aa0] underline underline-offset-2 hover:no-underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#2c5aa0]"
                  >
                    {citation.title || citation.source}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </>
    )
  }
</section>
