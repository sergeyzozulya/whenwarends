---
import type { BriefRow, Lang } from '@lib/types';
import { getTranslation } from '@i18n/index';

interface Props {
  /** The latest PUBLISHED brief for this lang, or null. */
  brief: BriefRow | null;
  /** True when showing last week's brief because no fresh one was approved. */
  isStale?: boolean;
  lang: Lang;
}

const { brief, isStale = false, lang } = Astro.props;

const sectionHeading = getTranslation(lang, 'brief.sectionHeading');
const sectionIntro = getTranslation(lang, 'brief.sectionIntro');
const disclaimer = getTranslation(lang, 'brief.disclaimer');
const headingLabel = getTranslation(lang, 'brief.heading');
const noBriefLabel = getTranslation(lang, 'brief.noBrief');
const reviewedLabel = getTranslation(lang, 'brief.reviewed');

// Drafts are never public. Only render published text; if it is null, the
// brief is treated as absent (no fresh brief notice).
const publishedText =
  brief != null && brief.published != null ? brief.published : null;
const hasBrief = publishedText != null;

// Per SPEC §10: when stale, the previous week's brief stays visible but with
// the "no fresh brief this week" notice above it.
const showNoBriefNotice = !hasBrief || (isStale && hasBrief);

// Localized published date, fixed to UTC per project time conventions.
const localeByLang: Record<Lang, string> = {
  uk: 'uk-UA',
  en: 'en-US',
  ru: 'ru-RU',
};

function formatDate(date: string | undefined): string | null {
  if (!date) return null;
  const d = new Date(`${date}T00:00:00Z`);
  if (Number.isNaN(d.getTime())) return null;
  return new Intl.DateTimeFormat(localeByLang[lang], {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  }).format(d);
}

const publishedDate = hasBrief ? formatDate(brief?.date) : null;

const paragraphs = (publishedText ?? '')
  .split(/\n{2,}/)
  .map((para) => para.trim())
  .filter((para) => para.length > 0);
---

<section aria-labelledby="brief-section-heading">
  <h2
    id="brief-section-heading"
    class="text-[22px] font-medium leading-[1.5] tracking-[-0.005em] text-[var(--color-ink)]"
  >
    {sectionHeading}
  </h2>
  <p class="mt-1 text-[16px] leading-[1.5] text-[var(--color-ink-soft)]">
    {sectionIntro}
  </p>
  <p class="mt-2 text-[13px] leading-[1.5] text-[var(--color-muted)]">
    {disclaimer}
  </p>

  {/* Two columns: the brief on the left, related news on the right. */}
  <div
    class="mt-7 rounded-xl border border-[var(--color-line)] bg-[var(--color-surface)] p-6 sm:p-8"
  >
    <div class="grid gap-6 lg:grid-cols-2 lg:gap-8">
      <div>
        <h3
          id="daily-brief-heading"
          class="text-[16px] font-medium leading-[1.5] text-[var(--color-ink)]"
        >
          {headingLabel}
        </h3>

        {
          hasBrief && (
            <p class="mt-1 text-[13px] text-[var(--color-muted)]">
              {publishedDate && (
                <>
                  <time datetime={brief?.date}>{publishedDate}</time>
                  <span> · </span>
                </>
              )}
              <span class="font-medium">{reviewedLabel}</span>
            </p>
          )
        }

        {
          showNoBriefNotice && (
            <p class="mt-1 text-[13px] text-[var(--color-muted)]" role="status">
              {noBriefLabel}
            </p>
          )
        }

        <div class="mt-4 space-y-4">
          {
            paragraphs.map((para) => (
              <p class="text-[16px] leading-[1.55] text-[var(--color-ink-soft)]">
                {para}
              </p>
            ))
          }
        </div>
      </div>
      <aside
        class="border-t border-[var(--color-line)] pt-6 lg:border-l lg:border-t-0 lg:pl-8 lg:pt-0"
      >
        <slot name="aside" />
      </aside>
    </div>
  </div>
</section>
