---
import { getTranslation } from '@i18n/index';
import type { Lang } from '@lib/types';

interface Props {
  lang: Lang;
  lastUpdated?: string; // ISO-8601 UTC
}

const { lang, lastUpdated } = Astro.props;

const t = (key: string): string => getTranslation(lang, key);

let lastUpdatedLabel: string | null = null;
if (lastUpdated) {
  const parsed = new Date(lastUpdated);
  if (!Number.isNaN(parsed.getTime())) {
    const formatted = new Intl.DateTimeFormat(lang, {
      timeZone: 'UTC',
      year: 'numeric',
      month: 'short',
      day: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
    }).format(parsed);
    lastUpdatedLabel = t('common.lastUpdated').replace('{date}', formatted);
  }
}
---

<footer class="border-t border-gray-200 mt-16">
  <div class="w-full px-4 py-8 sm:px-6 lg:px-12 xl:px-16">
    <div class="flex flex-wrap items-baseline justify-between gap-2">
      <p class="text-[13px] text-gray-500">{t('common.footer')}</p>
      {
        lastUpdatedLabel && (
          <p class="ml-auto text-right text-[13px] text-gray-500">
            {lastUpdatedLabel}
          </p>
        )
      }
    </div>
  </div>
</footer>
