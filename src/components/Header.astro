---
import { getTranslation } from '@i18n/index';
import type { Lang } from '@lib/types';
import { LANGS } from '@lib/types';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = (key: string): string => getTranslation(lang, key);

// Language label in its own script, matching the design (УК / EN / РУ).
const LABEL: Record<Lang, string> = { uk: 'УК', en: 'EN', ru: 'РУ' };
---

<header class="border-b border-[var(--color-line)]">
  <div
    class="mx-auto flex max-w-[1180px] items-center justify-between px-6 py-4 sm:px-12"
  >
    <a
      href={`/${lang}`}
      class="flex items-center gap-2 text-[var(--color-ink)] hover:no-underline"
    >
      <span
        class="inline-block h-3 w-3 rounded-[2px] bg-[var(--color-accent)]"
        aria-hidden="true"></span>
      <span class="text-[14px] font-medium tracking-tight">
        whenwarends.org
      </span>
    </a>

    <nav
      aria-label={t('common.language')}
      class="inline-flex overflow-hidden rounded-[3px] border border-[#e3e6ea] text-[13px]"
    >
      {
        LANGS.map((l, i) =>
          l === lang ? (
            <span
              aria-current="true"
              class={`bg-[#eef1f5] px-2.5 py-1 text-[var(--color-ink)] ${i > 0 ? 'border-l border-[#e3e6ea]' : ''}`}
            >
              {LABEL[l]}
            </span>
          ) : (
            <a
              href={`/${l}`}
              hreflang={l}
              data-set-lang={l}
              class={`px-2.5 py-1 text-[var(--color-muted)] hover:bg-[#f1f3f6] hover:text-[var(--color-ink)] hover:no-underline ${i > 0 ? 'border-l border-[#e3e6ea]' : ''}`}
            >
              {LABEL[l]}
            </a>
          )
        )
      }
    </nav>
  </div>
</header>
