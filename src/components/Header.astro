---
import { getTranslation } from '@i18n/index';
import type { Lang } from '@lib/types';
import { LANGS } from '@lib/types';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const t = (key: string): string => getTranslation(lang, key);

const navItems = [
  { key: 'common.home', href: `/${lang}` },
  { key: 'common.methodology', href: `/${lang}/methodology` },
  { key: 'common.about', href: `/${lang}/about` },
  { key: 'common.sources', href: `/${lang}/sources` },
  { key: 'common.changelog', href: `/${lang}/changelog` },
];
---

<header class="border-b border-gray-200">
  <div class="w-full px-4 py-4 sm:px-6 lg:px-12 xl:px-16">
    {/* One nav row, mobile-first: page links wrap on the left, the short
        language switcher stays pinned to the right. No masthead title —
        the page's single <h1> in <main> carries the brand. */}
    <div
      class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-3"
    >
      <nav
        aria-label="Primary"
        class="flex flex-wrap gap-x-6 gap-y-2 text-[16px]"
      >
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class="text-[#2c5aa0] hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#2c5aa0]"
            >
              {t(item.key)}
            </a>
          ))
        }
      </nav>

      <nav
        aria-label={t('common.language')}
        class="ml-auto flex items-center gap-3 text-[13px] lowercase"
      >
        {
          LANGS.map((l) =>
            l === lang ? (
              <span aria-current="true" class="text-gray-500">
                {l}
              </span>
            ) : (
              <a
                href={`/${l}`}
                hreflang={l}
                class="text-[#2c5aa0] hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#2c5aa0]"
              >
                {l}
              </a>
            )
          )
        }
      </nav>
    </div>
  </div>
</header>
