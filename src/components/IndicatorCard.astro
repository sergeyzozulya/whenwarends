---
import type { Lang } from '@lib/types';
import { getTranslation } from '@i18n/index';

interface Props {
  /** Already-localized card title. */
  title: string;
  /** Already-formatted primary value, e.g. "RUB 92.4 / USD" or "—". */
  value: string;
  /** Optional secondary line (e.g. delta, period). */
  sub?: string;
  /** 0–1; rendered as a small labeled quintile bar. Optional. */
  confidence?: number;
  /** If present, show the data-unavailable notice and de-emphasize the value. */
  degraded?: { sinceHours: number };
  /** If true, show the ISW-observed estimate note. */
  estimateNote?: boolean;
  lang: Lang;
}

const { title, value, sub, confidence, degraded, estimateNote, lang } =
  Astro.props;

const confidenceLabel = getTranslation(lang, 'ground.confidence');
const estimateLabel = getTranslation(lang, 'ground.estimateLabel');

// getTranslation does not interpolate; substitute {time} manually.
const degradedNotice = degraded
  ? getTranslation(lang, 'errors.dataUnavailable').replace(
      '{time}',
      `${degraded.sinceHours} hours`,
    )
  : null;

// Clamp to 0–1 and bucket into quintiles (1–5) for an accessible,
// non-color-only confidence indicator.
const hasConfidence = typeof confidence === 'number';
const clampedConfidence = hasConfidence
  ? Math.min(1, Math.max(0, confidence as number))
  : 0;
const confidencePct = Math.round(clampedConfidence * 100);
const filledQuintiles = hasConfidence
  ? Math.min(5, Math.max(1, Math.ceil(clampedConfidence * 5)))
  : 0;
const quintiles = [1, 2, 3, 4, 5];

const isDegraded = degraded != null;
---

<article class="flex flex-col gap-2 rounded border border-gray-200 bg-white p-4">
  <h3 class="text-base font-medium text-gray-700">{title}</h3>

  <p
    class:list={[
      'text-2xl font-normal leading-tight',
      isDegraded ? 'text-gray-400' : 'text-gray-900',
    ]}
  >
    {value}
  </p>

  {
    sub && (
      <p
        class:list={[
          'text-sm font-normal',
          isDegraded ? 'text-gray-400' : 'text-gray-600',
        ]}
      >
        {sub}
      </p>
    )
  }

  {
    hasConfidence && (
      <div class="mt-1 flex flex-col gap-1">
        <div class="flex items-baseline justify-between gap-2">
          <span class="text-xs font-medium text-gray-600">
            {confidenceLabel}
          </span>
          <span class="text-xs font-normal text-gray-600">
            {confidencePct}%
          </span>
        </div>
        <div
          class="flex gap-1"
          role="img"
          aria-label={`${confidenceLabel}: ${confidencePct}%`}
        >
          {quintiles.map((q) => (
            <span
              class:list={[
                'h-1.5 flex-1 rounded-sm',
                q <= filledQuintiles ? 'bg-[#2c5aa0]' : 'bg-gray-200',
              ]}
            />
          ))}
        </div>
      </div>
    )
  }

  {
    estimateNote && (
      <p class="text-xs font-normal text-gray-500">{estimateLabel}</p>
    )
  }

  {
    degradedNotice && (
      <p class="text-xs font-medium text-gray-600" role="status">
        {degradedNotice}
      </p>
    )
  }
</article>
