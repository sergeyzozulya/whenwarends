---
// Inline brief timeline (Phase 3): every past brief pinned to its date, with
// the metric picture as it stood then. Lets a reader scroll back and see
// "what the data showed, and what the brief said" at each point.
//
// Static .astro: no hydration. Reconstructed briefs are explicitly labelled
// so they are never read as contemporaneous editorial. All chrome localized.

import type { BriefArchiveEntry } from '@lib/homepage';
import type { Lang } from '@lib/types';
import { getTranslation } from '@i18n/index';

interface Props {
  entries: BriefArchiveEntry[];
  lang: Lang;
}

const { entries, lang } = Astro.props;

const heading = getTranslation(lang, 'brief.archiveHeading');
const sourcesLabel = getTranslation(lang, 'brief.sources');
const reconstructedLabel = getTranslation(lang, 'brief.reconstructed');
const aiLabel = getTranslation(lang, 'brief.reviewed');
const probLabel = getTranslation(lang, 'beliefs.current');
const intensityLabel = getTranslation(lang, 'ground.intensity');
const aidLabel = getTranslation(lang, 'ground.aid');
const economyLabel = getTranslation(lang, 'ground.economy');

const localeByLang: Record<Lang, string> = {
  uk: 'uk-UA',
  en: 'en-US',
  ru: 'ru-RU',
};

const dateFmt = new Intl.DateTimeFormat(localeByLang[lang], {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});

function formatDate(iso: string): string {
  const d = new Date(`${iso}T00:00:00Z`);
  return Number.isNaN(d.getTime()) ? iso : dateFmt.format(d);
}

const eur0 = new Intl.NumberFormat('en', {
  style: 'currency',
  currency: 'EUR',
  maximumFractionDigits: 0,
});

// One compact "what the data showed then" row. Each cell is omitted when
// there was no archived value by that date — never show a fabricated number.
function statCells(m: BriefArchiveEntry['metrics']) {
  const cells: { label: string; value: string }[] = [];
  if (m.warEndProbability.length > 0) {
    const avg =
      m.warEndProbability.reduce((s, w) => s + w.value, 0) /
      m.warEndProbability.length;
    cells.push({ label: probLabel, value: `${Math.round(avg * 100)}%` });
  }
  if (m.conflictIntensity !== null) {
    cells.push({
      label: intensityLabel,
      value: m.conflictIntensity.toFixed(1),
    });
  }
  if (m.aidEur !== null) {
    cells.push({ label: aidLabel, value: eur0.format(m.aidEur) });
  }
  if (m.rubUsd !== null) {
    cells.push({
      label: economyLabel,
      value: `${m.rubUsd.toFixed(2)} RUB / USD`,
    });
  }
  return cells;
}

const accent = '#2c5aa0';

const items = entries.map((e) => ({
  date: formatDate(e.date),
  paragraphs: e.text
    .split(/\n{2,}/)
    .map((p) => p.trim())
    .filter((p) => p.length > 0),
  citations: e.citations,
  reconstructed: e.reconstructed,
  stats: statCells(e.metrics),
}));
---

{
  items.length > 0 && (
    <section aria-labelledby="brief-timeline-heading" class="mt-12">
      <h2
        id="brief-timeline-heading"
        class="text-lg font-medium text-gray-900"
      >
        {heading}
      </h2>

      <ol class="mt-4 border-l border-gray-200">
        {items.map((item) => (
          <li class="relative ml-4 pb-8 pl-6">
            <span
              class="absolute -left-[7px] top-1.5 h-3 w-3 rounded-full border-2 border-white"
              style={`background:${accent}`}
              aria-hidden="true"
            />
            <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
              <time class="text-sm font-medium text-gray-900">
                {item.date}
              </time>
              <span class="text-xs font-medium text-gray-500">
                {item.reconstructed ? reconstructedLabel : aiLabel}
              </span>
            </div>

            {item.stats.length > 0 && (
              <dl class="mt-2 flex flex-wrap gap-x-6 gap-y-1">
                {item.stats.map((s) => (
                  <div class="flex items-baseline gap-1.5">
                    <dt class="text-xs font-normal text-gray-500">
                      {s.label}
                    </dt>
                    <dd class="text-xs font-medium text-gray-700">
                      {s.value}
                    </dd>
                  </div>
                ))}
              </dl>
            )}

            <div class="mt-3 space-y-3">
              {item.paragraphs.map((p) => (
                <p class="text-sm font-normal leading-relaxed text-gray-800">
                  {p}
                </p>
              ))}
            </div>

            {item.citations.length > 0 && (
              <div class="mt-3">
                <h3 class="text-xs font-medium text-gray-700">
                  {sourcesLabel}
                </h3>
                <ul class="mt-1 space-y-1">
                  {item.citations.map((c) => (
                    <li class="text-xs font-normal text-gray-700">
                      <a
                        href={c.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="underline underline-offset-2 hover:no-underline focus:outline-none focus:ring-2 focus:ring-offset-2"
                        style={`color:${accent}`}
                      >
                        {c.title || c.source}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </li>
        ))}
      </ol>
    </section>
  )
}
