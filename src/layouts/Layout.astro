---
// Base layout for all pages
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import type { Lang } from '@lib/types';
import { getTranslation } from '@i18n/index';
import '@/styles/global.css';

interface Props {
  title: string;
  lang: string;
  lastUpdated?: string; // ISO-8601 UTC
}

const { title, lang, lastUpdated } = Astro.props;

// `lang` is typed as string for backward compatibility with existing pages;
// Header/Footer require the Lang union. Pages only ever pass a valid locale.
const locale = lang as Lang;

// Social-share metadata. og:image is the per-locale build-time PNG, so it
// always carries the latest numbers; URLs are absolute (Astro.site).
const og = (k: string) => getTranslation(locale, k);
const ogTitle = og('common.title');
const ogDesc = og('common.subtitle');
const ogImage = new URL(`/${locale}/og.png`, Astro.site).href;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!DOCTYPE html>
<html lang={lang} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={ogDesc} />
    <link rel="canonical" href={canonical} />
    <title>{title} — whenwarends.org</title>

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="whenwarends.org" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDesc} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDesc} />
    <meta name="twitter:image" content={ogImage} />
    {/* Language preference: a saved choice wins; otherwise auto-detect
        from the browser (saved choice is only written when the user
        explicitly switches — see the [data-set-lang] handler). Runs
        before paint to avoid a flash. */}
    <script is:inline>
      (function () {
        try {
          var sup = ['uk', 'en', 'ru'];
          var parts = location.pathname.split('/').filter(Boolean);
          var cur = parts[0];
          if (sup.indexOf(cur) === -1) return;
          var stored = localStorage.getItem('lang');
          var target = null;
          if (stored && sup.indexOf(stored) !== -1) {
            target = stored;
          } else if (!stored) {
            var navs = navigator.languages || [navigator.language || 'en'];
            for (var i = 0; i < navs.length; i++) {
              var l = (navs[i] || '').toLowerCase();
              if (l.indexOf('uk') === 0) { target = 'uk'; break; }
              if (l.indexOf('ru') === 0) { target = 'ru'; break; }
              if (l.indexOf('en') === 0) { target = 'en'; break; }
            }
            if (!target) target = 'en';
          }
          if (target && target !== cur) {
            parts[0] = target;
            location.replace(
              '/' + parts.join('/') + location.search + location.hash
            );
          }
        } catch (e) {}
      })();
    </script>

    {/* Google Analytics 4, Consent Mode v2 — analytics_storage stays
        DENIED permanently (no consent is ever granted), so GA runs
        cookieless: no _ga cookie, no client identifier, only coarse
        aggregate pings. No consent banner is needed because nothing
        consent-triggering is ever stored on the device. */}
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-KN7G44T186"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied',
      });
      gtag('config', 'G-KN7G44T186');
    </script>
  </head>
  <body>
    <Header lang={locale} />

    <main
      class="mx-auto w-full max-w-[1180px] px-6 pb-20 pt-[88px] sm:px-12"
    >
      <slot />
    </main>

    <Footer lang={locale} lastUpdated={lastUpdated} />

    {/* Persist an explicit language choice (the switcher carries
        data-set-lang); the head script then honours it on later visits. */}
    <script is:inline>
      document.addEventListener('click', function (e) {
        var a = e.target && e.target.closest
          ? e.target.closest('[data-set-lang]')
          : null;
        if (!a) return;
        try {
          localStorage.setItem('lang', a.getAttribute('data-set-lang'));
        } catch (err) {}
      });
    </script>
  </body>
</html>
