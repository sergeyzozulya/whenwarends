---
// Base layout for all pages
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import type { Lang } from '@lib/types';
import '@/styles/global.css';

interface Props {
  title: string;
  lang: string;
  lastUpdated?: string; // ISO-8601 UTC
}

const { title, lang, lastUpdated } = Astro.props;

// `lang` is typed as string for backward compatibility with existing pages;
// Header/Footer require the Lang union. Pages only ever pass a valid locale.
const locale = lang as Lang;
---

<!DOCTYPE html>
<html lang={lang} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="A market-implied probability for the end of the Russia-Ukraine war, surrounded by the measured data moving the curve."
    />
    <title>{title} — whenwarends.org</title>
    {/* Language preference: a saved choice wins; otherwise auto-detect
        from the browser (saved choice is only written when the user
        explicitly switches — see the [data-set-lang] handler). Runs
        before paint to avoid a flash. */}
    <script is:inline>
      (function () {
        try {
          var sup = ['uk', 'en', 'ru'];
          var parts = location.pathname.split('/').filter(Boolean);
          var cur = parts[0];
          if (sup.indexOf(cur) === -1) return;
          var stored = localStorage.getItem('lang');
          var target = null;
          if (stored && sup.indexOf(stored) !== -1) {
            target = stored;
          } else if (!stored) {
            var navs = navigator.languages || [navigator.language || 'en'];
            for (var i = 0; i < navs.length; i++) {
              var l = (navs[i] || '').toLowerCase();
              if (l.indexOf('uk') === 0) { target = 'uk'; break; }
              if (l.indexOf('ru') === 0) { target = 'ru'; break; }
              if (l.indexOf('en') === 0) { target = 'en'; break; }
            }
            if (!target) target = 'en';
          }
          if (target && target !== cur) {
            parts[0] = target;
            location.replace(
              '/' + parts.join('/') + location.search + location.hash
            );
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <Header lang={locale} />

    <main
      class="mx-auto w-full max-w-[1180px] px-6 pb-20 pt-[88px] sm:px-12"
    >
      <slot />
    </main>

    <Footer lang={locale} lastUpdated={lastUpdated} />

    {/* Persist an explicit language choice (the switcher carries
        data-set-lang); the head script then honours it on later visits. */}
    <script is:inline>
      document.addEventListener('click', function (e) {
        var a = e.target && e.target.closest
          ? e.target.closest('[data-set-lang]')
          : null;
        if (!a) return;
        try {
          localStorage.setItem('lang', a.getAttribute('data-set-lang'));
        } catch (err) {}
      });
    </script>
  </body>
</html>
