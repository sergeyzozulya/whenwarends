---
// Base layout for all pages
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import type { Lang } from '@lib/types';
import '@/styles/global.css';

interface Props {
  title: string;
  lang: string;
  lastUpdated?: string; // ISO-8601 UTC
}

const { title, lang, lastUpdated } = Astro.props;

// `lang` is typed as string for backward compatibility with existing pages;
// Header/Footer require the Lang union. Pages only ever pass a valid locale.
const locale = lang as Lang;
---

<!DOCTYPE html>
<html lang={lang} dir={lang === 'uk' ? 'ltr' : lang === 'ru' ? 'ltr' : 'ltr'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="A dashboard answering: when does this war end?" />
    <title>{title} — When War Ends</title>
  </head>
  <body class="bg-white text-gray-900">
    <Header lang={locale} lastUpdated={lastUpdated} />

    <main class="max-w-5xl mx-auto px-4 py-8 sm:px-6 lg:px-8">
      <slot />
    </main>

    <Footer lang={locale} />
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-size: 16px;
    line-height: 1.5;
    color: #111827;
  }

  a {
    color: #2c5aa0;
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  h1,
  h2,
  h3 {
    font-weight: 500;
  }

  h1 {
    font-size: 22px;
  }

  h2 {
    font-size: 18px;
  }

  h3 {
    font-size: 16px;
  }
</style>
