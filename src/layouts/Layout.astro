---
// Base layout for all pages
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import type { Lang } from '@lib/types';
import { getTranslation, localizedPath } from '@i18n/index';
import '@/styles/global.css';

interface Props {
  title: string;
  lang: string;
  lastUpdated?: string; // ISO-8601 UTC
}

const { title, lang, lastUpdated } = Astro.props;

// `lang` is typed as string for backward compatibility with existing pages;
// Header/Footer require the Lang union. Pages only ever pass a valid locale.
const locale = lang as Lang;

// Social-share metadata. og:image is the per-locale build-time PNG, so it
// always carries the latest numbers; URLs are absolute (Astro.site).
const og = (k: string) => getTranslation(locale, k);
const ogTitle = og('common.title');
const ogDesc = og('common.subtitle');
const ogImage = new URL(localizedPath(locale, '/og.png'), Astro.site).href;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

// hreflang alternates: the same page in each locale (en is unprefixed, so only
// strip a locale segment when the current page is prefixed). x-default → en.
const segs = Astro.url.pathname.split('/').filter(Boolean);
const pageRest = (locale === 'en' ? segs : segs.slice(1)).join('/');
const altHref = (l: Lang) =>
  new URL(localizedPath(l, pageRest ? `/${pageRest}` : ''), Astro.site).href;
const ALT_LANGS = ['uk', 'en', 'ru'] as const;
---

<!DOCTYPE html>
<html lang={lang} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={ogDesc} />
    <link rel="canonical" href={canonical} />
    {ALT_LANGS.map((l) => (
      <link rel="alternate" hreflang={l} href={altHref(l)} />
    ))}
    <link rel="alternate" hreflang="x-default" href={altHref('en')} />
    <title>{title} — whenwarends.org</title>

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="whenwarends.org" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDesc} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDesc} />
    <meta name="twitter:image" content={ogImage} />
    {/* Language auto-redirect — deliberately narrow so it never interferes
        with indexing. It fires ONLY when all three hold: (1) no explicit choice
        is stored, (2) the visitor is on the unprefixed root ('/'), and (3) the
        browser prefers uk/ru over en. Every other path — including localized
        pages — is left untouched, so a crawler (which renders with en and
        stores nothing) reaches each page directly instead of through a
        redirect. An explicit switch is saved by the [data-set-lang] handler and
        suppresses (1). Runs before paint to avoid a flash. */}
    <script is:inline>
      (function () {
        try {
          var parts = location.pathname.split('/').filter(Boolean);
          if (parts.length !== 0) return;            // not the root page
          if (localStorage.getItem('lang')) return;  // explicit choice set
          var navs = navigator.languages || [navigator.language || 'en'];
          var target = 'en';
          for (var i = 0; i < navs.length; i++) {
            var l = (navs[i] || '').toLowerCase();
            if (l.indexOf('uk') === 0) { target = 'uk'; break; }
            if (l.indexOf('ru') === 0) { target = 'ru'; break; }
            if (l.indexOf('en') === 0) { target = 'en'; break; }
          }
          if (target !== 'en') {
            location.replace('/' + target + '/' + location.search + location.hash);
          }
        } catch { /* navigation is best-effort; ignore */ }
      })();
    </script>

    {/* Google Analytics 4, Consent Mode v2 — analytics_storage stays
        DENIED permanently (no consent is ever granted), so GA runs
        cookieless: no _ga cookie, no client identifier, only coarse
        aggregate pings. No consent banner is needed because nothing
        consent-triggering is ever stored on the device. */}
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-KN7G44T186"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied',
      });
      gtag('config', 'G-KN7G44T186');
    </script>

    {/* Cloudflare Web Analytics — cookieless, privacy-first beacon. No cookie,
        no identifier, no consent banner needed; gives a second, independent
        visitor count alongside GA. The token is public by design (it is exposed
        in the page HTML), so it is hardcoded like the GA measurement ID. */}
    <script
      is:inline
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "f600c5d50d2c4341aca69d988c78460b"}'
    ></script>
  </head>
  <body>
    <Header lang={locale} />

    <main
      class="mx-auto w-full max-w-[1180px] px-6 pb-20 pt-[88px] sm:px-12"
    >
      <slot />
    </main>

    <Footer lang={locale} lastUpdated={lastUpdated} />

    {/* Persist an explicit language choice (the switcher carries
        data-set-lang); the head script then honours it on later visits. */}
    <script is:inline>
      document.addEventListener('click', function (e) {
        var a = e.target && e.target.closest
          ? e.target.closest('[data-set-lang]')
          : null;
        if (!a) return;
        try {
          localStorage.setItem('lang', a.getAttribute('data-set-lang'));
        } catch { /* localStorage may be unavailable; ignore */ }
      });
    </script>
  </body>
</html>
