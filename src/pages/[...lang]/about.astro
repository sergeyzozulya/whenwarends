---
// About — what this is, who makes it, and its posture.
import Layout from '@/layouts/Layout.astro';
import { getTranslation } from '@i18n/index';
import type { Lang } from '@lib/types';

export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'uk' } },
    { params: { lang: 'ru' } },
  ];
}

const lang = (Astro.params.lang ?? 'en') as Lang;
const t = (key: string) => getTranslation(lang, key);
const contactEmail = 'hello@whenwarends.org';

interface Block {
  h: string;
  p: string[];
}
interface Page {
  lede: string;
  blocks: Block[];
}

const CONTENT: Record<Lang, Page> = {
  en: {
    lede: 'A non-commercial, Ukrainian-built dashboard that answers one question with calm, transparent data: when does this war end?',
    blocks: [
      {
        h: 'Why it exists',
        p: [
          'People who live with this war — at home and abroad — deserve a sober, honest reference point that is neither doom-scrolling nor false comfort. The advocacy is in choosing to build it; the presentation stays restrained and never sensational.',
        ],
      },
      {
        h: 'What it does',
        p: [
          'It shows a market-implied probability distribution for the end of the war, a scrubbable timeline of measured indicators (conflict, currency, GDP, inflation), and a short weekly editorial brief — with a list of related news beside it — that is auto-published behind code-level integrity guards. It never authors its own prediction.',
        ],
      },
      {
        h: 'How it is built',
        p: [
          'A static-first Astro site on Cloudflare\'s free tier, fed only by free and open data sources. No ads, no accounts, no paid tiers. Analytics is cookieless — Google Analytics (Consent Mode left denied) and Cloudflare Web Analytics set no cookies or identifiers, do no cross-site or cross-session tracking, and record only coarse, aggregate traffic.',
          'The full method is on the methodology page; every data source and licence is on the sources page; every change is logged on the changelog.',
        ],
      },
      {
        h: 'Licence and contact',
        p: [
          `Non-commercial, built in Kharkiv by {ITSUA}, released under CC BY 4.0. Contact: ${contactEmail}.`,
        ],
      },
    ],
  },
  uk: {
    lede: 'Некомерційний інформаційний застосунок, створений в Україні, що відповідає на одне питання спокійними, прозорими даними: коли закінчиться ця війна?',
    blocks: [
      {
        h: 'Навіщо це',
        p: [
          'Люди, які живуть із цією війною — удома й за кордоном — заслуговують на тверезий, чесний орієнтир, який не є ані безкінечним негативом, ані фальшивою втіхою. Позиція — у самому рішенні це створити; подача залишається стриманою й несенсаційною.',
        ],
      },
      {
        h: 'Що він робить',
        p: [
          'Показує ринковий розподіл імовірності завершення війни, хронологію виміряних показників із прокручуванням (конфлікт, валюта, ВВП, інфляція) і короткий щотижневий редакційний огляд — із переліком пов’язаних новин поруч — що публікується автоматично під захистом програмних запобіжників цілісності. Сайт ніколи не створює власного прогнозу.',
        ],
      },
      {
        h: 'Як це побудовано',
        p: [
          'Статичний сайт на Astro на безкоштовному тарифі Cloudflare, що живиться лише безкоштовними й відкритими джерелами. Без реклами, без акаунтів, без платних рівнів. Аналітика без кук — Google Analytics (Consent Mode залишено на «denied») і Cloudflare Web Analytics не встановлюють кук чи ідентифікаторів, не ведуть міжсайтового чи міжсесійного відстеження й фіксують лише грубий агрегований трафік.',
          'Повна методологія — на сторінці методології; усі джерела та ліцензії — на сторінці джерел; усі зміни — в історії змін.',
        ],
      },
      {
        h: 'Ліцензія та контакт',
        p: [
          `Некомерційний, створений у Харкові командою {ITSUA}, поширюється за CC BY 4.0. Контакт: ${contactEmail}.`,
        ],
      },
    ],
  },
  ru: {
    lede: 'Некоммерческое приложение, созданное в Украине, отвечающее на один вопрос спокойными, прозрачными данными: когда закончится эта война?',
    blocks: [
      {
        h: 'Зачем это',
        p: [
          'Люди, живущие с этой войной — дома и за рубежом — заслуживают трезвый, честный ориентир, который не является ни бесконечным негативом, ни ложным утешением. Позиция — в самом решении это создать; подача остаётся сдержанной и несенсационной.',
        ],
      },
      {
        h: 'Что он делает',
        p: [
          'Показывает рыночное распределение вероятности завершения войны, прокручиваемую хронологию измеренных показателей (конфликт, валюта, ВВП, инфляция) и короткую еженедельную редакционную сводку — со списком связанных новостей рядом — которая публикуется автоматически под защитой программных гарантий целостности. Сайт никогда не создаёт собственный прогноз.',
        ],
      },
      {
        h: 'Как это построено',
        p: [
          'Статический сайт на Astro на бесплатном тарифе Cloudflare, питающийся только бесплатными и открытыми источниками. Без рекламы, без аккаунтов, без платных уровней. Аналитика без кук — Google Analytics (Consent Mode оставлен на «denied») и Cloudflare Web Analytics не устанавливают кук или идентификаторов, не ведут межсайтового или межсессионного отслеживания и фиксируют только грубый агрегированный трафик.',
          'Полная методология — на странице методологии; все источники и лицензии — на странице источников; все изменения — в истории изменений.',
        ],
      },
      {
        h: 'Лицензия и контакт',
        p: [
          `Некоммерческий, создан в Харькове командой {ITSUA}, распространяется по CC BY 4.0. Контакт: ${contactEmail}.`,
        ],
      },
    ],
  },
};

const c = CONTENT[lang];
---

<Layout lang={lang} title={t('common.about')}>
  <article class="max-w-2xl space-y-10">
    <header class="space-y-2">
      <h1 class="text-[22px] font-medium">{t('common.about')}</h1>
      <p class="text-[16px] text-gray-600">{c.lede}</p>
    </header>
    {
      c.blocks.map((b) => (
        <section class="space-y-3">
          <h2 class="text-[18px] font-medium">{b.h}</h2>
          {b.p.map((para) => (
            <p class="text-[16px]">
              {para.split('{ITSUA}').flatMap((seg, i) =>
                i === 0
                  ? [seg]
                  : [
                      <a
                        href="https://itsua.com/"
                        rel="noopener noreferrer"
                        class="text-[var(--color-accent)] hover:no-underline"
                      >
                        ITSUA
                      </a>,
                      seg,
                    ]
              )}
            </p>
          ))}
        </section>
      ))
    }
  </article>
</Layout>
