---
// Changelog page — rendered from data/changelog.json at build time.
import Layout from '@/layouts/Layout.astro';
import { getTranslation } from '@i18n/index';
import type { Lang, ChangelogRow } from '@lib/types';
import { readChangelog } from '@lib/filestore';

export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'uk' } },
    { params: { lang: 'ru' } },
  ];
}

const lang = (Astro.params.lang ?? 'en') as Lang;
const t = (key: string) => getTranslation(lang, key);

const entries = [...readChangelog()].sort((a, b) =>
  b.date.localeCompare(a.date)
);
const descOf = (e: ChangelogRow): string =>
  lang === 'uk' ? e.description_uk : lang === 'ru' ? e.description_ru : e.description_en;
// Unknown category keys fall back to the raw key rather than a missing string.
const catOf = (e: ChangelogRow): string => {
  const label = t(`changelog.cat.${e.category}`);
  return label === `changelog.cat.${e.category}` ? e.category : label;
};
const dateFmt = new Intl.DateTimeFormat(lang, {
  dateStyle: 'medium',
  timeZone: 'UTC',
});
---

<Layout lang={lang} title={t('common.changelog')}>
  <section class="max-w-2xl space-y-6">
    <h1 class="text-[22px] font-medium">{t('common.changelog')}</h1>
    {
      entries.length === 0 ? (
        <p class="text-[13px] text-gray-500">—</p>
      ) : (
        <ul class="space-y-4">
          {entries.map((e) => (
            <li class="border-b border-gray-200 pb-4">
              <div class="flex items-baseline gap-3">
                <time datetime={e.date} class="text-[13px] text-gray-500">
                  {dateFmt.format(new Date(e.date + 'T00:00:00Z'))}
                </time>
                <span class="text-[13px] text-gray-500">{catOf(e)}</span>
              </div>
              <p class="mt-1 text-[16px]">{descOf(e)}</p>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</Layout>
