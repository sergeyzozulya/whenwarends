---
// Changelog page
import Layout from '@/layouts/Layout.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'uk' } },
    { params: { lang: 'en' } },
    { params: { lang: 'ru' } },
  ];
}

const { lang } = Astro.params;
---

<Layout lang={lang} title="Changelog">
  <main class="max-w-2xl mx-auto prose">
    <h1>Changelog</h1>
    <dl>
      <dt>2026-05-17</dt>
      <dd>Phase 0 — Project scaffold, Astro i18n routing, GitHub Actions CI</dd>
    </dl>
  </main>
</Layout>
