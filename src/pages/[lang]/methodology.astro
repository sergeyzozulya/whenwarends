---
// Metadata page
import Layout from '@/layouts/Layout.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'uk' } },
    { params: { lang: 'en' } },
    { params: { lang: 'ru' } },
  ];
}

const { lang } = Astro.params;
---

<Layout lang={lang} title="Methodology">
  <main class="max-w-2xl mx-auto prose">
    <h1>Methodology</h1>
    <p>Coming in Phase 3: detailed methodology for data sources, market aggregation, and CDF computation.</p>
  </main>
</Layout>
