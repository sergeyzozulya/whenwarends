---
// Data sources — what feeds each part of the site, and under what licence.
import Layout from '@/layouts/Layout.astro';
import { getTranslation } from '@i18n/index';
import type { Lang } from '@lib/types';

export function getStaticPaths() {
  return [{ params: { lang: 'uk' } }, { params: { lang: 'en' } }, { params: { lang: 'ru' } }];
}

const lang = Astro.params.lang as Lang;
const t = (key: string) => getTranslation(lang, key);

interface Source {
  name: string;
  url: string;
  license: string;
  use: Record<Lang, string>;
}

const FEEDS: Source[] = [
  {
    name: 'Polymarket (Gamma + Data API)',
    url: 'https://polymarket.com',
    license: 'Public',
    use: {
      en: 'Primary war-end probabilities and history.',
      uk: 'Основні ймовірності завершення війни та історія.',
      ru: 'Основные вероятности завершения войны и история.',
    },
  },
  {
    name: 'Kalshi (public market data)',
    url: 'https://kalshi.com',
    license: 'Public',
    use: {
      en: 'Secondary forecast signal.',
      uk: 'Додатковий сигнал прогнозу.',
      ru: 'Дополнительный сигнал прогноза.',
    },
  },
  {
    name: 'GDELT 2.0',
    url: 'https://www.gdeltproject.org',
    license: 'CC BY',
    use: {
      en: 'Conflict intensity and tone.',
      uk: 'Інтенсивність бойових дій і тональність.',
      ru: 'Интенсивность боевых действий и тональность.',
    },
  },
  {
    name: 'Kiel Ukraine Support Tracker',
    url: 'https://www.ifw-kiel.de/topics/war-against-ukraine/ukraine-support-tracker/',
    license: 'CC BY 4.0',
    use: {
      en: 'Aid commitments, converted to EUR at the daily ECB rate.',
      uk: 'Зобов’язання щодо допомоги, переведені в євро за курсом ЄЦБ.',
      ru: 'Обязательства по помощи, переведённые в евро по курсу ЕЦБ.',
    },
  },
  {
    name: 'NASA FIRMS',
    url: 'https://firms.modaps.eosdis.nasa.gov',
    license: 'Public domain',
    use: {
      en: 'Fire/heat anomalies as a combat-zone proxy.',
      uk: 'Теплові аномалії як непрямий показник бойової зони.',
      ru: 'Тепловые аномалии как косвенный показатель боевой зоны.',
    },
  },
  {
    name: 'World Bank',
    url: 'https://data.worldbank.org/country/russian-federation',
    license: 'Public',
    use: {
      en: 'Russian macro indicators.',
      uk: 'Макропоказники Росії.',
      ru: 'Макропоказатели России.',
    },
  },
  {
    name: 'National Bank of Ukraine',
    url: 'https://bank.gov.ua',
    license: 'Public',
    use: {
      en: 'UAH exchange rate.',
      uk: 'Курс гривні.',
      ru: 'Курс гривны.',
    },
  },
  {
    name: 'Central Bank of Russia',
    url: 'https://www.cbr.ru',
    license: 'Public',
    use: {
      en: 'RUB exchange rate (official daily feed).',
      uk: 'Курс рубля (офіційний денний фід).',
      ru: 'Курс рубля (официальный дневной фид).',
    },
  },
  {
    name: 'European Central Bank (via Frankfurter)',
    url: 'https://www.ecb.europa.eu',
    license: 'Public',
    use: {
      en: 'Daily reference rates for currency conversion.',
      uk: 'Денні довідкові курси для конвертації валют.',
      ru: 'Дневные справочные курсы для конвертации валют.',
    },
  },
];

const CITED: Source[] = [
  {
    name: 'Institute for the Study of War (ISW)',
    url: 'https://www.understandingwar.org',
    license: 'Cited & linked only',
    use: {
      en: 'Basis for the frontline estimate; fair-use citation, never republished.',
      uk: 'Основа оцінки фронту; цитування за принципом добросовісного використання, без передруку.',
      ru: 'Основа оценки фронта; цитирование по принципу добросовестного использования, без перепечатки.',
    },
  },
  {
    name: 'Russia Matters',
    url: 'https://www.russiamatters.org',
    license: 'Cited & linked only',
    use: {
      en: 'Contextual reference; fair-use citation, never republished.',
      uk: 'Контекстне посилання; цитування за принципом добросовісного використання.',
      ru: 'Контекстная ссылка; цитирование по принципу добросовестного использования.',
    },
  },
];

const STR: Record<Lang, { lede: string; feeds: string; cited: string; useCol: string; licenceCol: string; footer: string }> = {
  en: {
    lede: 'Every figure is traceable to a free, open, publicly accessible source. Nothing here is paid, scraped against terms, or behind a login.',
    feeds: 'Data feeds',
    cited: 'Cited references (not ingested)',
    useCol: 'Use',
    licenceCol: 'Licence',
    footer: 'This project is non-commercial and released under CC BY 4.0. Attributed datasets are credited above; ISW and Russia Matters are cited and linked only, never republished beyond fair use.',
  },
  uk: {
    lede: 'Кожен показник простежується до безкоштовного, відкритого, публічно доступного джерела. Нічого платного, зібраного всупереч умовам чи за входом.',
    feeds: 'Джерела даних',
    cited: 'Цитовані джерела (не імпортуються)',
    useCol: 'Використання',
    licenceCol: 'Ліцензія',
    footer: 'Проєкт некомерційний і поширюється за CC BY 4.0. Набори даних атрибутовано вище; ISW і Russia Matters лише цитуються та лінкуються, без передруку поза добросовісним використанням.',
  },
  ru: {
    lede: 'Каждый показатель прослеживается до бесплатного, открытого, публично доступного источника. Ничего платного, собранного вопреки условиям или за логином.',
    feeds: 'Источники данных',
    cited: 'Цитируемые источники (не импортируются)',
    useCol: 'Использование',
    licenceCol: 'Лицензия',
    footer: 'Проект некоммерческий и распространяется по CC BY 4.0. Наборы данных атрибутированы выше; ISW и Russia Matters только цитируются и линкуются, без перепечатки за пределами добросовестного использования.',
  },
};

const s = STR[lang];

const renderRows = (rows: Source[]) =>
  rows.map((r) => ({
    name: r.name,
    url: r.url,
    license: r.license,
    use: r.use[lang],
  }));
---

<Layout lang={lang} title={t('common.sources')}>
  <article class="max-w-2xl space-y-8">
    <header class="space-y-2">
      <h1 class="text-[22px] font-medium">{t('common.sources')}</h1>
      <p class="text-[16px] text-gray-600">{s.lede}</p>
    </header>

    {
      [
        { title: s.feeds, rows: renderRows(FEEDS) },
        { title: s.cited, rows: renderRows(CITED) },
      ].map((group) => (
        <section class="space-y-3">
          <h2 class="text-[18px] font-medium">{group.title}</h2>
          <ul class="divide-y divide-gray-200 border-t border-gray-200">
            {group.rows.map((r) => (
              <li class="py-3">
                <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                  <a
                    class="text-[16px] text-[#2c5aa0] hover:underline"
                    href={r.url}
                    rel="noopener noreferrer"
                  >
                    {r.name}
                  </a>
                  <span class="text-[13px] text-gray-500">
                    {s.licenceCol}: {r.license}
                  </span>
                </div>
                <p class="mt-1 text-[16px] text-gray-700">{r.use}</p>
              </li>
            ))}
          </ul>
        </section>
      ))
    }

    <p class="border-t border-gray-200 pt-4 text-[13px] text-gray-500">{s.footer}</p>
  </article>
</Layout>
