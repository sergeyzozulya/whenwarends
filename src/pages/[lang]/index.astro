---
// Homepage — editorial layout matching docs/whenwarends - standalone.html.
import Layout from '@/layouts/Layout.astro';
import HeroChart from '@/components/HeroChart';
import HistoryTimeline from '@/components/HistoryTimeline';
import { getTranslation } from '@i18n/index';
import type { Lang } from '@lib/types';
import { loadHomePayload } from '@lib/homepage';
import { isoToMs, probColor, type HeroMarket } from '@lib/heroChartData';

export function getStaticPaths() {
  return [{ params: { lang: 'uk' } }, { params: { lang: 'en' } }, { params: { lang: 'ru' } }];
}

const lang = Astro.params.lang as Lang;
const t = (key: string) => getTranslation(lang, key);
const data = loadHomePayload(lang);

const localeByLang: Record<Lang, string> = {
  uk: 'uk-UA',
  en: 'en-US',
  ru: 'ru-RU',
};
const loc = localeByLang[lang];

const heroStrings: Record<string, string> = {
  label: t('hero.label'),
  definition: t('hero.definition'),
  ceasefire: t('hero.ceasefire'),
  peaceDeal: t('hero.peaceDeal'),
  either: t('hero.either'),
  todayMarker: t('hero.todayMarker'),
  crossing50: t('hero.crossing50'),
  chartAria: t('hero.chartAria'),
  legendCurve: t('hero.legendCurve'),
  legendMarket: t('hero.legendMarket'),
  legendCrossing: t('hero.legendCrossing'),
  bkt_ceasefireAgreement: t('hero.bktCeasefireAgreement'),
  bkt_ceasefire: t('hero.bktCeasefire'),
  bkt_peaceDeal: t('hero.bktPeaceDeal'),
  bkt_framework: t('hero.bktFramework'),
  bkt_leadership: t('hero.bktLeadership'),
  bkt_other: t('hero.bktOther'),
};

const historyStrings: Record<string, string> = {
  heading: t('history.heading'),
  scrubIntro: t('history.scrubIntro'),
  scrubAria: t('history.scrubAria'),
  asOf: t('history.asOf'),
  now: t('history.now'),
  play: t('history.play'),
  pause: t('history.pause'),
  per12m: t('history.per12m'),
  intensity: t('history.iConflict'),
  tone: t('history.iTone'),
  fire: t('history.iFire'),
  uah: t('history.iUah'),
  rub: t('history.iRub'),
  uaGdp: t('history.iUaGdp'),
  ruGdp: t('history.iRuGdp'),
  uaCpi: t('history.iUaCpi'),
  ruCpi: t('history.iRuCpi'),
  ruLoss: t('history.iRuLoss'),
  uaLoss: t('history.iUaLoss'),
  aid: t('history.iAid'),
  lossNote: t('history.lossNote'),
  locale: loc,
};

// --- Stat cards: median (consensus) + most-optimistic active market ---
const mkts: HeroMarket[] = data.hero.markets ?? [];
const nMarkets = mkts.length;


const fmtMonthYearFmt = new Intl.DateTimeFormat(loc, {
  year: 'numeric',
  month: 'long',
  timeZone: 'UTC',
});
// Intl lowercases month names in uk/ru ("грудень"/"декабрь") — capitalize.
const fmtMonthYear = {
  format(d: Date): string {
    const s = fmtMonthYearFmt.format(d);
    return s.charAt(0).toUpperCase() + s.slice(1);
  },
};

// Card 1 — the market point sitting closest to the fitted consensus curve
// (the most representative bet). Always resolves, unlike the 50% CDF
// crossing, which is null while near-term war-end probability stays < 50%.
const curvePts = (data.hero.datasets.ceasefire?.curve ?? [])
  .map((c) => ({ x: isoToMs(c.date), p: c.probability }))
  .filter((c) => Number.isFinite(c.x))
  .sort((a, b) => a.x - b.x);

function consensusAt(x: number): number | null {
  if (curvePts.length === 0) return null;
  if (x <= curvePts[0].x) return curvePts[0].p;
  const last = curvePts[curvePts.length - 1];
  if (x >= last.x) return last.p;
  for (let i = 0; i < curvePts.length - 1; i++) {
    const a = curvePts[i];
    const b = curvePts[i + 1];
    if (x >= a.x && x <= b.x) {
      const tt = b.x === a.x ? 0 : (x - a.x) / (b.x - a.x);
      return a.p + tt * (b.p - a.p);
    }
  }
  return last.p;
}

let closestM: HeroMarket | null = null;
let bestDist = Infinity;
for (const m of mkts) {
  const c = consensusAt(m.x);
  if (c === null) continue;
  const d = Math.abs(m.y - c);
  if (d < bestDist) {
    bestDist = d;
    closestM = m;
  }
}

const closestValue = closestM
  ? `${Math.round(closestM.y * 100)}% · ${fmtMonthYear.format(
      new Date(closestM.x)
    )}`
  : '—';
const closestColor = closestM ? probColor(closestM.y) : undefined;

const nowMs = Date.now();
const futureM = mkts.filter((m) => m.x >= nowMs);
let optimisticM: HeroMarket | null = null;
for (const m of futureM.length > 0 ? futureM : mkts) {
  if (
    optimisticM === null ||
    m.y > optimisticM.y ||
    (m.y === optimisticM.y && m.x < optimisticM.x)
  ) {
    optimisticM = m;
  }
}

const fmtLiq = (v: number | null): string => {
  if (v == null || !Number.isFinite(v)) return '—';
  if (v >= 1000) return `$${Math.round(v / 1000)}k`;
  return `$${Math.round(v)}`;
};

const optimisticValue = optimisticM
  ? `${Math.round(optimisticM.y * 100)}% · ${fmtMonthYear.format(
      new Date(optimisticM.x)
    )}`
  : '—';
const optimisticColor = optimisticM ? probColor(optimisticM.y) : undefined;
const optimisticMeta = optimisticM
  ? `${optimisticM.source} · ${optimisticM.question}`
  : t('hero.noMarket');
const optimisticImplied = optimisticM
  ? t('hero.implied')
      .replace('{p}', `${Math.round(optimisticM.y * 100)}%`)
      .replace('{liq}', fmtLiq(optimisticM.liquidity))
  : '';

const closestMeta = closestM
  ? `${closestM.source} · ${closestM.question}`
  : t('hero.noMarket');
const closestImplied = closestM
  ? t('hero.implied')
      .replace('{p}', `${Math.round(closestM.y * 100)}%`)
      .replace('{liq}', fmtLiq(closestM.liquidity))
  : '';

const nMarketsLabel = t('hero.nMarkets').replace('{n}', String(nMarkets));
heroStrings.nMarkets = nMarketsLabel;

const cardCls =
  'rounded-xl border border-[var(--color-line)] bg-[var(--color-surface)]';
---

<Layout
  lang={lang}
  title={t('common.title')}
  lastUpdated={data.lastUpdated ?? undefined}
>
  <div class="space-y-10">
    {/* Hero */}
    <section>
      <h1
        class="text-[clamp(40px,6vw,72px)] font-normal leading-[1.02] tracking-[-0.025em] text-[var(--color-ink)]"
      >
        {t('common.title')}
      </h1>
      <p
        class="mt-5 text-[18px] leading-[1.55] text-[var(--color-ink-soft)]"
      >
        {t('common.subtitle')}
      </p>
    </section>

    {/* Probability card */}
    <section class={`${cardCls} p-8`}>
      <h2
        class="text-[22px] font-medium leading-[1.5] tracking-[-0.005em] text-[var(--color-ink)]"
      >
        {t('hero.label')}
      </h2>
      <p class="mt-1 text-[13px] text-[var(--color-muted)]">
        {t('hero.caption')}
      </p>
      <div class="mt-7">
        <HeroChart
          client:load
          datasets={data.hero.datasets}
          today={data.hero.today}
          markets={data.hero.markets}
          strings={heroStrings}
        />
      </div>
    </section>

    {/* Two stat cards */}
    <section class="grid grid-cols-1 gap-5 md:grid-cols-2">
      <article class={`${cardCls} p-8`}>
        <div class="flex items-baseline gap-2.5">
          <h2 class="text-[13px] text-[var(--color-muted)]">
            {t('hero.closest')}
          </h2>
          <span
            class="rounded-[2px] border border-[#3b6b97]/15 px-1.5 py-px text-[11px] tracking-[0.44px] text-[var(--color-accent)]"
          >
            {t('hero.medianTag')}
          </span>
        </div>
        <p
          class="mt-1.5 text-[36px] font-normal leading-[1.1] tracking-[-0.018em]"
          style={closestColor ? `color:${closestColor}` : undefined}
        >
          {closestValue}
        </p>
        <p class="mt-7 text-[13px] leading-[1.5] text-[var(--color-muted)]">
          {closestMeta}
        </p>
        {
          closestImplied && (
            <p class="mt-3 flex gap-2 text-[13px] text-[var(--color-muted)]">
              <span aria-hidden="true">→</span>
              <span>{closestImplied}</span>
            </p>
          )
        }
      </article>

      <article class={`${cardCls} p-8`}>
        <div class="flex items-baseline gap-2.5">
          <h2 class="text-[13px] text-[var(--color-muted)]">
            {t('hero.optimistic')}
          </h2>
          <span
            class="rounded-[2px] border border-[#3b6b97]/15 px-1.5 py-px text-[11px] tracking-[0.44px] text-[var(--color-accent)]"
          >
            {t('hero.optimisticTag')}
          </span>
        </div>
        <p
          class="mt-1.5 text-[36px] font-normal leading-[1.1] tracking-[-0.018em]"
          style={optimisticColor ? `color:${optimisticColor}` : undefined}
        >
          {optimisticValue}
        </p>
        <p class="mt-7 text-[13px] leading-[1.5] text-[var(--color-muted)]">
          {optimisticMeta}
        </p>
        {
          optimisticImplied && (
            <p class="mt-3 flex gap-2 text-[13px] text-[var(--color-muted)]">
              <span aria-hidden="true">→</span>
              <span>{optimisticImplied}</span>
            </p>
          )
        }
      </article>
    </section>

    {/* The war in data */}
    <section>
      <h2
        class="text-[22px] font-medium leading-[1.5] tracking-[-0.005em] text-[var(--color-ink)]"
      >
        {t('history.heading')}
      </h2>
      <p
        class="mt-1 text-[16px] leading-[1.5] text-[var(--color-ink-soft)]"
      >
        {t('history.scrubIntro')}
      </p>
      <div class={`${cardCls} mt-7 p-8`}>
        <HistoryTimeline
          client:visible
          history={data.history}
          strings={historyStrings}
        />
      </div>
    </section>
  </div>
</Layout>
