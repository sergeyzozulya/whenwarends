---
// About page
import Layout from '@/layouts/Layout.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'uk' } },
    { params: { lang: 'en' } },
    { params: { lang: 'ru' } },
  ];
}

const { lang } = Astro.params;
---

<Layout lang={lang} title="About">
  <main class="max-w-2xl mx-auto prose">
    <h1>About</h1>
    <p>A non-commercial, Ukrainian-built dashboard that answers a single question with calm, transparent data: when does this war end?</p>
    <p>Static-first Astro site on Cloudflare's free tier, fed by free and open data sources only.</p>
  </main>
</Layout>
