{
  "name": "whenwarends",
  "version": "0.1.0",
  "description": "A non-commercial dashboard answering: when does this war end?",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx,.astro",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "perf": "tsx scripts/check-bundle.ts",
    "collect": "tsx scripts/collect.ts",
    "collect-news": "tsx scripts/collect-news.ts",
    "seed-card-metrics": "tsx scripts/seed-card-metrics.ts",
    "draft-brief": "tsx scripts/draft-brief.ts",
    "backfill-briefs": "tsx scripts/backfill-briefs.ts",
    "import:firms-archive": "tsx scripts/import-firms-archive.ts",
    "collect:gdelt-history": "tsx scripts/gdelt-history.ts",
    "collect:firms-history": "tsx scripts/firms-history.ts",
    "wrangler:dev": "npm run build && wrangler dev",
    "wrangler:deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@astrojs/react": "^4.4.2",
    "@fontsource-variable/inter": "^5.2.8",
    "astro": "^5.0.0",
    "chart.js": "^4.4.1",
    "exceljs": "^4.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.0.0",
    "undici": "^7.25.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@cloudflare/workers-types": "^4.20260420.1",
    "@fontsource/inter": "^5.2.8",
    "@playwright/test": "^1.60.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.55.0",
    "eslint-plugin-astro": "^0.30.0",
    "playwright": "^1.40.1",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "tsx": "^4.22.1",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4",
    "wrangler": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
