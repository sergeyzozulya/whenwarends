{
  "name": "whenwarends",
  "version": "0.1.0",
  "description": "A non-commercial dashboard answering: when does this war end?",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "perf": "tsx scripts/check-bundle.ts",
    "collect": "tsx scripts/collect.ts",
    "collect-news": "tsx scripts/collect-news.ts",
    "seed-card-metrics": "tsx scripts/seed-card-metrics.ts",
    "draft-brief": "tsx scripts/draft-brief.ts",
    "import:firms-archive": "tsx scripts/import-firms-archive.ts",
    "collect:gdelt-history": "tsx scripts/gdelt-history.ts",
    "collect:firms-history": "tsx scripts/firms-history.ts",
    "collect:frontline-history": "tsx scripts/frontline-history.ts",
    "wrangler:dev": "npm run build && wrangler dev",
    "wrangler:deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@astrojs/react": "^5.0.5",
    "@fontsource-variable/inter": "^5.2.8",
    "astro": "^6.3.7",
    "chart.js": "^4.4.1",
    "exceljs": "^4.4.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.0.0",
    "undici": "^8.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@cloudflare/workers-types": "^4.20260524.1",
    "@eslint/js": "^10.0.0",
    "@fontsource/inter": "^5.2.8",
    "@playwright/test": "^1.60.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.6.0",
    "playwright": "^1.40.1",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "wrangler": "^4.94.0"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
