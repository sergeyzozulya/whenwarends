{
  "name": "whenwarends",
  "version": "0.1.0",
  "description": "A non-commercial dashboard answering: when does this war end?",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx,.astro || true",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "wrangler:dev": "npm run build && wrangler dev",
    "wrangler:deploy": "npm run build && wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply whenwarends_db --remote"
  },
  "dependencies": {
    "astro": "^5.0.0",
    "chart.js": "^4.4.1",
    "zod": "^3.22.4",
    "@tailwindcss/vite": "^4.0.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260420.1",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.55.0",
    "eslint-plugin-astro": "^0.30.0",
    "playwright": "^1.40.1",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4",
    "wrangler": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
